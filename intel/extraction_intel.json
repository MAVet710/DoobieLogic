{
  "module": "extraction_intel",
  "version": "1.0",
  "units": {
    "yield": "percent_of_input_mass"
  },
  "methods": {
    "BHO": {
      "workflow_stages": [
        "biomass_prep",
        "hydrocarbon_extraction",
        "winterization_optional",
        "solvent_recovery",
        "post_processing",
        "qa_release"
      ],
      "yield_range_percent": {
        "min": 8,
        "max": 22
      },
      "common_losses": [
        "channeling_in_column",
        "incomplete_solvent_recovery",
        "overheating_during_purge",
        "transfer_loss_between_vessels"
      ],
      "typical_outputs": ["shatter", "badder", "live_resin", "diamonds_plus_sauce"],
      "formulation_required_when": [
        "target_vape_viscosity_not_met",
        "native_terpenes_below_spec"
      ],
      "terpene_handling": {
        "native": "Can be retained with low-temperature purge and live input.",
        "reintroduced": "Often used in cartridges for sensory consistency."
      },
      "failure_points": [
        "unsafe_pressure_or_leaks",
        "high_residual_solvents",
        "inconsistent_nucleation"
      ],
      "efficiency_indicators": [
        "solvent_recovery_rate",
        "throughput_kg_per_shift",
        "pass_rate_first_qa"
      ]
    },
    "CO2": {
      "workflow_stages": [
        "biomass_prep",
        "supercritical_extraction",
        "fraction_collection",
        "dewaxing",
        "distillation_or_polish",
        "qa_release"
      ],
      "yield_range_percent": {"min": 6, "max": 18},
      "common_losses": [
        "suboptimal_pressure_temperature_profile",
        "fraction_cross_contamination",
        "waxes_left_in_oil"
      ],
      "typical_outputs": ["crude_oil", "distillate_feedstock", "co2_vape_oil"],
      "formulation_required_when": ["flavor_profile_is_flat", "viscosity_out_of_spec"],
      "terpene_handling": {
        "native": "Fractionation can preserve light terpenes when tuned.",
        "reintroduced": "Common after polishing/distillation for flavor restoration."
      },
      "failure_points": ["compressor_downtime", "fractionation_misalignment"],
      "efficiency_indicators": ["run_cycle_time", "co2_recycle_efficiency", "dewaxing_rework_rate"]
    },
    "Ethanol": {
      "workflow_stages": [
        "biomass_prep",
        "cold_or_warm_soak",
        "solid_liquid_separation",
        "ethanol_recovery",
        "winterization",
        "distillation_or_refinement",
        "qa_release"
      ],
      "yield_range_percent": {"min": 10, "max": 25},
      "common_losses": [
        "chlorophyll_pickup_from_warm_soak",
        "ethanol_evaporation_loss",
        "distillation_hold_up"
      ],
      "typical_outputs": ["crude", "winterized_oil", "distillate", "edible_input_oil"],
      "formulation_required_when": ["used_for_vape_or_tincture_targets"],
      "terpene_handling": {
        "native": "Often reduced in aggressive recovery/distillation.",
        "reintroduced": "Frequently needed for vape-ready profiles."
      },
      "failure_points": ["insufficient_chilling", "residual_solvent_failure"],
      "efficiency_indicators": ["solvent_recovery_percent", "post_winterization_loss_percent", "distillate_pass_rate"]
    },
    "Rosin": {
      "workflow_stages": [
        "input_selection_flower_or_hash",
        "conditioning",
        "press_cycle",
        "collection",
        "optional_cure",
        "qa_release"
      ],
      "yield_range_percent": {"min": 10, "max": 30},
      "common_losses": ["overdry_input", "blowouts", "plate_temp_too_high"],
      "typical_outputs": ["solventless_rosin", "jam", "sauce"],
      "formulation_required_when": ["rosin_used_as_vape_fill"],
      "terpene_handling": {
        "native": "Primarily native terpene expression when process is controlled.",
        "reintroduced": "Rare; typically avoided for solventless positioning."
      },
      "failure_points": ["darkening_from_heat", "inconsistent_press_pressure"],
      "efficiency_indicators": ["yield_per_press", "micron_bag_failure_rate", "return_to_input_value_ratio"]
    },
    "Ice Water Hash": {
      "workflow_stages": [
        "fresh_frozen_prep",
        "agitation_in_ice_water",
        "sieve_separation",
        "drying",
        "grading",
        "qa_release"
      ],
      "yield_range_percent": {"min": 3, "max": 8},
      "common_losses": ["overagitation_contaminants", "improper_drying", "mesh_transfer_loss"],
      "typical_outputs": ["bubble_hash", "full_melt_hash", "rosin_feedstock"],
      "formulation_required_when": ["hash_upcycled_into_vape_or_ingredients"],
      "terpene_handling": {
        "native": "High native retention with fresh frozen material.",
        "reintroduced": "Usually not required for premium solventless use-cases."
      },
      "failure_points": ["microbial_risk_from_slow_drying", "oxidation"],
      "efficiency_indicators": ["first_wash_yield_share", "melt_grade_distribution", "drying_time_within_spec"]
    },
    "Dry Sift": {
      "workflow_stages": [
        "cured_input_prep",
        "sieving_by_mesh",
        "static_cleanup",
        "grading",
        "optional_pressing",
        "qa_release"
      ],
      "yield_range_percent": {"min": 2, "max": 12},
      "common_losses": ["plant_contamination", "overworking_material", "handling_loss"],
      "typical_outputs": ["kief", "sift_hash", "rosin_feedstock"],
      "formulation_required_when": ["used_in_vape_or_edible_manufacturing"],
      "terpene_handling": {
        "native": "Moderate retention with gentle handling.",
        "reintroduced": "Can be used for product consistency in manufactured goods."
      },
      "failure_points": ["low_purity", "oxidation_during_storage"],
      "efficiency_indicators": ["purity_percent", "grade_a_fraction", "rework_rate"]
    }
  }
}
