{
  "module": "financial_intel",
  "version": "1.1",
  "cost_logic": {
    "cost_per_gram": "total_run_cost / max(total_output_grams, 0.01)",
    "run_cost_components": ["input_biomass_cost", "labor_cost", "solvent_or_utilities", "packaging_cost", "qa_and_compliance_cost"]
  },
  "value_logic": {
    "value_per_gram": "expected_revenue / max(total_output_grams, 0.01)",
    "drivers": ["product_mix", "channel_price", "brand_tier", "potency_or_quality_grade"]
  },
  "margin_logic": {
    "gross_margin": "(revenue - cost) / max(revenue, 0.01)",
    "contribution_margin": "(revenue - variable_costs) / max(revenue, 0.01)",
    "cash_margin": "(cash_collections - cash_operating_costs) / max(cash_collections, 0.01)"
  },
  "working_capital": {
    "inventory_carrying_cost_components": ["capital_cost", "storage", "insurance", "obsolescence", "shrink_and_destroy"],
    "warning_signals": ["aging_inventory_90_plus", "increasing_markdown_dependency", "inventory_growth_outpacing_sales"]
  },
  "commercial_heuristics": {
    "pricing_strategy": [
      "Use price ladders to protect entry/core/premium architecture.",
      "Treat discounting as inventory-shaping tool, not default demand lever."
    ],
    "overbuying_risk": "PO_volume > 60_day_expected_demand should trigger scenario review",
    "under_assortment_signal": "high_stockout_rate_in_top_category indicates missed revenue",
    "operational_roi_examples": ["line_changeover_reduction", "yield_uplift_program", "packaging_fpy_improvement"]
  },
  "yield_to_profit_relationships": [
    {"id": "low_yield_high_cost", "rule": "if yield_percent < target and cost_per_gram > category_benchmark then bad_run"},
    {"id": "high_yield_low_value", "rule": "if yield_percent > target and value_per_gram < benchmark then misleading_success"},
    {"id": "balanced_success", "rule": "yield_within_target and value_per_gram_above_benchmark and margin_above_floor"},
    {"id": "margin_without_cash", "rule": "if gross_margin_healthy and cash_margin_weak then working_capital_pressure"}
  ]
}
